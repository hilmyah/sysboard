# SysBoard environment configuration
# Copy this file to .env and fill in real values:
#   cp .env.example .env && chmod 600 .env
# systemd reads this file via EnvironmentFile= in sysboard.service

# Required: static token for all API requests.
# Generate a strong value with: openssl rand -hex 32
SYSBOARD_TOKEN=<YOUR_SYSBOARD_TOKEN>

# Optional: TCP port to listen on. Default: 8888
SYSBOARD_PORT=8888
