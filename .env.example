# SysBoard environment configuration
# Copy this file to .env and fill in real values:
#   cp .env.example .env && chmod 600 .env
# systemd reads this file via EnvironmentFile= in sysboard.service

# Required: static token used to authenticate all API requests.
# Use a long random string. Example: openssl rand -hex 32
SYSBOARD_TOKEN=<YOUR_SYSBOARD_TOKEN>

# Optional: TCP port to listen on. Default: 8888
SYSBOARD_PORT=8888 # Change this if you want to run SysBoard on a different port.

# Optional: path to Minecraft Bedrock server log file.
# Set to empty string to disable the Minecraft tab entirely.
# Default: /var/log/bedrock-server.log
SYSBOARD_LOG_PATH=/var/log/bedrock-server.log
